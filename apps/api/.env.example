# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME=Modern ERP API
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# ============================================
# Database (PostgreSQL)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=erp
DB_PASSWORD=erp_dev_password
DB_DATABASE=modern_erp
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT
# ============================================
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars-long-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-secret-also-min-32-chars-long-change-me-too
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Security
# ============================================
BCRYPT_COST=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
